{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "prConcurrentLimit": 10,
  "dependencyDashboard": true,
  "labels": [
    "dependencies"
  ],
  "extends": [
    "config:recommended",
    "group:kubernetesMonorepo",
    ":enablePreCommit",
    ":pinVersions"
  ],
  "flux": {
    "managerFilePatterns": [
      "/(?:^|/)gotk-components\\.ya?ml$/",
      "/(?:^|/)kubernetes(?:/.+)?/repository\\.ya?ml$/",
      "/(?:^|/)kubernetes(?:/.+)?/release\\.ya?ml$/",
      "/(?:^|/)kubernetes(?:/.+)?/app\\.ya?ml$/"
    ]
  },
  "kubernetes": {
    "managerFilePatterns": [
      "/(?:^|/)kubernetes(?:/.+)?/*\\.ya?ml$/"
    ]
  },
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/(?:^|/)kubernetes/infra/crds/kustomization\\.ya?ml$/",
        "/(?:^|/)terraform/modules/talos-bootstrap/templates/control_plane.yaml.tftpl$/"
      ],
      "matchStrings": [
        "https://github.com/(?<depName>[^/]+/[^/]+)//[^?]+\\?ref=(?<currentValue>.*?)\\s",
        "https://raw.githubusercontent.com/(?<depName>[^/]+/[^/]+)/(?<currentValue>[^/]+)/"
      ],
      "datasourceTemplate": "github-releases",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/(?:^|/)terraform/production/terraform.tfvars$/"
      ],
      "matchStrings": [
        "talos_version\\s*=\\s*\"(?<currentValue>[^\"]+)\""
      ],
      "depNameTemplate": "siderolabs/talos",
      "datasourceTemplate": "github-releases",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/(?:^|/)terraform/modules/talos-bootstrap/network.tf$/"
      ],
      "matchStrings": [
        "chart\\s*=\\s*\"(?<depName>[^\"]+)\"[\\s\\S]*?version\\s*=\\s*\"(?<currentValue>[^\"]+)\""
      ],
      "datasourceTemplate": "helm",
      "registryUrlTemplate": "https://helm.cilium.io/",
      "versioningTemplate": "semver"
    }
  ],
  "terraform": {
    "managerFilePatterns": [
      "/\\.tf$/"
    ]
  },
  "packageRules": [
    {
      "groupName": "fluxcd",
      "matchFileNames": [
        "kubernetes/clusters/**/flux-system/gotk-components.yaml",
        "kubernetes/clusters/**/flux-system/gotk-components.yml"
      ],
      "matchPackageNames": [
        "fluxcd/flux2",
        "ghcr.io/fluxcd/**",
        "docker.io/fluxcd/**"
      ]
    },
    {
      "groupName": "cilium",
      "matchPackageNames": [
        "cilium"
      ],
      "matchDatasources": [
        "helm"
      ]
    },
    {
      "description": "Regenerate Terraform docs after Terraform dependency updates",
      "matchManagers": [
        "terraform"
      ],
      "matchFileNames": [
        "terraform/**"
      ],
      "postUpgradeTasks": {
        "commands": [
          "./tools/renovate/update-terraform-docs.sh"
        ],
        "fileFilters": [
          "terraform/**/README.md"
        ],
        "executionMode": "update"
      }
    }
  ]
}
