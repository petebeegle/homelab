{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "prConcurrentLimit": 10,
  "dependencyDashboard": true,
  "labels": [
    "dependencies"
  ],
  "extends": [
    "config:recommended",
    "group:kubernetes",
    ":enablePreCommit",
    ":pinVersions"
  ],
  "flux": {
    "fileMatch": [
      "(?:^|/)gotk-components\\.ya?ml$",
      "(?:^|/)kubernetes(?:/.+)?/repository\\.ya?ml$",
      "(?:^|/)kubernetes(?:/.+)?/release\\.ya?ml$"
    ]
  },
  "kubernetes": {
    "fileMatch": [
      "(?:^|/)kubernetes(?:/.+)?/*\\.ya?ml$"
    ]
  },
  "customManagers": [
    {
      "fileMatch": [
        "(?:^|/)kubernetes/infra/crds/kustomization\\.ya?ml$",
        "(?:^|/)terraform/cluster/modules/talos-bootstrap/templates/control_plane\.yaml\.tftpl$"
      ],
      "matchStrings": [
        "https://github\.com/(?<depName>[^/]+/[^/]+)//[^?]+\\?ref=(?<currentValue>.*?)\\s",
        "https://raw\.githubusercontent\.com/(?<depName>[^/]+/[^/]+)/(?<currentValue>[^/]+)/"
      ],
      "datasourceTemplate": "github-releases",
      "versioningTemplate": "semver"
    },
    {
      "fileMatch": [
        "(?:^|/)terraform/cluster/terraform\.tfvars$"
      ],
      "matchStrings": [
        "talos_version\\s*=\\s*\"(?<currentValue>[^\"]+)\""
      ],
      "depNameTemplate": "siderolabs/talos",
      "datasourceTemplate": "github-releases",
      "versioningTemplate": "semver"
    },
    {
      "fileMatch": [
        "(?:^|/)terraform/cluster/modules/talos-bootstrap/network\.tf$"
      ],
      "matchStrings": [
        "chart\\s*=\\s*\"(?<depName>[^\"]+)\"[\\s\\S]*?version\\s*=\\s*\"(?<currentValue>[^\"]+)\""
      ],
      "datasourceTemplate": "helm",
      "registryUrlTemplate": "https://helm.cilium.io/",
      "versioningTemplate": "semver"
    }
  ],
  "terraform": {
    "fileMatch": [
      "\\.tf$"
    ]
  },
  "packageRules": [
    {
      "groupName": "cilium",
      "matchPackageNames": ["cilium"],
      "matchDatasources": ["helm"]
    }
  ]
}
